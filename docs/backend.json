
{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer inquiry for building maintenance and repair services",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the customer"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email address"
        },
        "serviceType": {
          "type": "string",
          "enum": ["하자보수", "방수공사", "도장공사", "시설관리", "기타"],
          "description": "The type of service requested"
        },
        "content": {
          "type": "string",
          "description": "Detailed description of the inquiry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the inquiry was created"
        }
      },
      "required": ["name", "phone", "serviceType", "content"]
    },
    "Portfolio": {
      "title": "Portfolio",
      "description": "A portfolio item showcasing completed construction work",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "제목 (예: 아파트 외벽 균열 보수)" },
        "category": { "type": "string", "enum": ["하자보수", "방수", "도장", "기타"], "description": "카테고리" },
        "subText": { "type": "string", "description": "소제목 (예: 공동주택 · 경기도)" },
        "imageUrl": { "type": "string", "description": "이미지 URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "imageUrl"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of customer inquiries"
    },
    "/portfolios/{portfolioId}": {
      "schema": "Portfolio",
      "description": "Collection of construction portfolio items"
    }
  }
}
